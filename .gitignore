# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids/.keep
!/tmp/storage/.keep

# Ignore master key
/config/master.key
/config/credentials/*.key

# Ignore storage
/storage/*
!/storage/.keep

# macOS
.DS_Store
